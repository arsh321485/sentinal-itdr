# SentinelForge ITDR — copy to .env and fill in secrets
# setup.sh generates this automatically on first run

SF_DATA_DIR=/opt/sentinelforge/data
SF_CERTS_DIR=/opt/sentinelforge/certs
SF_CONFIG_DIR=/opt/sentinelforge/config

POSTGRES_USER=sentinelforge
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES
POSTGRES_DB=sentinelforge

MINIO_ROOT_USER=sentinelforge
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO

KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_KEYCLOAK

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA

NEO4J_PASSWORD=CHANGE_ME_NEO4J

VAULT_TOKEN=

# Client deployment
PORTAL_DOMAIN=forge.clientdomain.com
DEFAULT_TENANT_ID=default
